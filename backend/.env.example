# Database (Neon local/CI or Render Postgres)
# Async URL for SQLAlchemy + asyncpg. Render injects DATABASE_URL in production.
# If DATABASE_URL is unset, DATABASE_URL_DEV is used (local dev).
DATABASE_URL=
DATABASE_URL_DEV=postgresql+asyncpg://user:password@host:5432/dbname
# Dedicated test DB for local pytest and CI overrides.
DATABASE_URL_TEST=postgresql+asyncpg://user:password@host:5432/dbname_test

# JWT (generate a long random string for production)
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookie for refresh token (API host; cross-site from Vercel)
REFRESH_COOKIE_NAME=dashflow_refresh
REFRESH_COOKIE_SECURE=false
# lax | strict | none (none + secure for cross-site SPA → API)
REFRESH_COOKIE_SAMESITE=lax
# Comma-separated origins, no spaces
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Render sets PORT in production
PORT=8000
